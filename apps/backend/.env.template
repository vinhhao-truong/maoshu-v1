# ── How environment files work ───────────────────────────────────────────────
# .env              Shared vars (CORS, JWT, etc.) — same in all environments.
# .env.development  Local overrides — loaded when NODE_ENV=development (medusa develop).
# .env.production   Prod overrides  — loaded when NODE_ENV=production  (medusa start).
# Both .env.development and .env.production are gitignored; never commit them.
# ─────────────────────────────────────────────────────────────────────────────

# ── .env (shared) ────────────────────────────────────────────────────────────
MEDUSA_ADMIN_ONBOARDING_TYPE=nextjs
MEDUSA_ADMIN_ONBOARDING_NEXTJS_DIRECTORY=maoshu-v1\apps\storefront
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
# REDIS_URL=redis://localhost:6379

# ── .env.development ─────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medusa_dev

# ── .env.production ──────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
# S3_REGION=ap-northeast-2
# S3_BUCKET=media
# S3_ACCESS_KEY_ID=<from Supabase dashboard → Storage → S3 connection>
# S3_SECRET_ACCESS_KEY=<from Supabase dashboard → Storage → S3 connection>
# S3_FILE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/media
